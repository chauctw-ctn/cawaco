# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (PostgreSQL on Supabase)
DATABASE_URL=postgresql://username:password@host:port/database

# JWT Secret (change this to a strong random string)
JWT_SECRET=your-secret-key-here-change-me

# MQTT Broker Configuration
MQTT_BROKER=mqtt://14.225.252.85
MQTT_PORT=1883
MQTT_TOPIC=telemetry

# TVA System Configuration
TVA_URL=http://camau.dulieuquantrac.com:8906
TVA_LOGIN_URL=http://camau.dulieuquantrac.com:8906/index.php?module=users&view=users&task=checklogin
TVA_USERNAME=your-tva-username
TVA_PASSWORD=your-tva-password

# SCADA TVA Configuration
SCADA_URL=http://14.161.36.253:86
SCADA_LOGIN_URL=http://14.161.36.253:86/Scada/Login.aspx
